from pathlib import Path
import pandas as pd

# Use both raw folders, but avoid duplicate sample names
raw_dirs = [
    Path("../GSE136103_RAW"),
    Path("../GSE136103_RAW 2")
]

sample_records = []

for raw_dir in raw_dirs:
    for matrix_file in sorted(raw_dir.glob("*_matrix.mtx.gz")):
        sample_name = matrix_file.name.replace("_matrix.mtx.gz", "")
        
        # Keep human liver healthy/cirrhotic only
        if ("blood" in sample_name.lower()) or ("mouse" in sample_name.lower()):
            continue
        
        if ("healthy" not in sample_name.lower()) and ("cirrhotic" not in sample_name.lower()):
            continue
        
        condition = "healthy" if "healthy" in sample_name.lower() else "cirrhotic"
        
        if "cd45+" in sample_name.lower():
            cd45_status = "cd45+"
        elif "cd45-" in sample_name.lower():
            cd45_status = "cd45-"
        else:
            cd45_status = "unknown"
        
        sample_records.append({
            "sample_name": sample_name,
            "base_path": raw_dir,
            "condition": condition,
            "cd45_status": cd45_status,
            "matrix_file": matrix_file
        })

sample_table = pd.DataFrame(sample_records)

# Remove duplicate samples if RAW and RAW 2 contain same files
sample_table = (
    sample_table
    .drop_duplicates(subset="sample_name")
    .sort_values("sample_name")
    .reset_index(drop=True)
)

print("Number of human liver samples:", len(sample_table))
sample_table

# %%
sample_table[["condition", "cd45_status"]].value_counts().sort_index()

# %%
# Load all human liver samples

adatas = []

for _, row in sample_table.iterrows():
    sample_name = row["sample_name"]
    base_path = row["base_path"]
    condition = row["condition"]
    cd45_status = row["cd45_status"]
    
    adata = load_sample(
        sample_name=sample_name,
        base_path=base_path,
        condition=condition,
        cd45_status=cd45_status
    )
    
    adatas.append(adata)

adata_all = sc.concat(
    adatas,
    join="outer",
    label="batch",
    keys=sample_table["sample_name"].tolist()
)

adata_all

