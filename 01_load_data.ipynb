# %%
#funtcion to load one sample
def load_sample(sample_name, base_path, condition, cd45_status):
    print(f"Loading {sample_name}")
    
    # Load matrix and transpose to cells x genes
    adata = sc.read(base_path / f"{sample_name}_matrix.mtx.gz").T
    
    # Load cell barcodes
    barcodes = pd.read_csv(
        base_path / f"{sample_name}_barcodes.tsv.gz",
        header=None
    )
    adata.obs_names = [f"{sample_name}_{bc}" for bc in barcodes[0].values]
    
    # Load genes
    genes = pd.read_csv(
        base_path / f"{sample_name}_genes.tsv.gz",
        header=None,
        sep="\t"
    )
    
    # Column 0 = Ensembl IDs, Column 1 = gene symbols
    adata.var["gene_ids"] = genes[0].values
    adata.var_names = genes[1].values
    adata.var_names_make_unique()
    
    # Add sample metadata
    adata.obs["sample_id"] = sample_name
    adata.obs["condition"] = condition
    adata.obs["cd45_status"] = cd45_status
    
    return adata

# %%
#load test samples
samples_to_load = [
    ("GSM4041159_healthy4_cd45-", "../GSE136103_RAW", "healthy", "cd45-"),
    ("GSM4041161_cirrhotic1_cd45+", "../GSE136103_RAW", "cirrhotic", "cd45+")
]

adatas = []

for sample_name, folder, condition, cd45_status in samples_to_load:
    adata = load_sample(
        sample_name=sample_name,
        base_path=Path(folder),
        condition=condition,
        cd45_status=cd45_status
    )
    adatas.append(adata)

adata_combined = sc.concat(adatas, join="outer", label="batch")
adata_combined

# %%
#QC metrics
adata_combined.var["mt"] = adata_combined.var_names.str.startswith("MT-")

sc.pp.calculate_qc_metrics(
    adata_combined,
    qc_vars=["mt"],
    percent_top=None,
    log1p=False,
    inplace=True
)

adata_combined.obs[
    ["sample_id", "condition", "cd45_status", "n_genes_by_counts", "total_counts", "pct_counts_mt"]
].head()

# %%
#QC Plots
sc.pl.violin(
    adata_combined,
    ["n_genes_by_counts", "total_counts", "pct_counts_mt"],
    groupby="condition",
    rotation=45,
    multi_panel=True
)

# %%
#chrk marker genes are readable 
marker_genes = ["COL1A1", "ACTA2", "TREM2", "CD9", "PECAM1", "VWF", "MT-CO1"]

for gene in marker_genes:
    print(gene, gene in adata_combined.var_names)

# %%
#more QC
adata_qc = adata_combined.copy()

print("Before filtering:", adata_qc.shape)

adata_qc = adata_qc[
    (adata_qc.obs["n_genes_by_counts"] > 300) &
    (adata_qc.obs["n_genes_by_counts"] < 6000) &
    (adata_qc.obs["pct_counts_mt"] < 20)
].copy()

print("After filtering:", adata_qc.shape)

# %%
sc.pl.violin(
    adata_qc,
    ["n_genes_by_counts", "total_counts", "pct_counts_mt"],
    groupby="condition",
    rotation=45,
    multi_panel=True
)

# %%
#Normalize + highly varibale genes
adata_proc = adata_qc.copy()

# Save raw counts
adata_proc.layers["counts"] = adata_proc.X.copy()

# Normalize counts per cell
sc.pp.normalize_total(adata_proc, target_sum=1e4)

# Log transform
sc.pp.log1p(adata_proc)

# Find highly variable genes
sc.pp.highly_variable_genes(
    adata_proc,
    n_top_genes=3000,
    subset=False
)

adata_proc

# %%
#plot variable genes
sc.pl.highly_variable_genes(adata_proc)

# %%
# PCA + neighbors + UMAP + clustering

# Scale data
sc.pp.scale(adata_proc, max_value=10)

# PCA
sc.tl.pca(
    adata_proc,
    svd_solver='arpack',
    random_state=0
)

# Compute neighborhood graph
sc.pp.neighbors(
    adata_proc,
    n_neighbors=15,
