# %%
from pathlib import Path

# Make output folder
outdir = Path("../results/celltype_DE")
outdir.mkdir(parents=True, exist_ok=True)

# Cell types to analyze
celltypes_to_test = [
    "Fibroblast_Stellate",
    "Endothelial",
    "Myeloid",
    "T_cells",
    "NK_cells",
    "Epithelial",
    "Mast"
]

de_results = {}

for celltype in celltypes_to_test:
    print(f"\n===== {celltype} =====")
    
    subset = adata_markers[
        adata_markers.obs["cell_type"] == celltype
    ].copy()
    
    counts = subset.obs["condition"].value_counts()
    print(counts)
    
    # Skip if both conditions are not present
    if len(counts) < 2:
        print(f"Skipping {celltype}: only one condition present")
        continue
    
    # Skip if too few cells in either condition
    if counts.min() < 20:
        print(f"Skipping {celltype}: too few cells in one condition")
        continue
    
    # Run DE: cirrhotic vs healthy
    sc.tl.rank_genes_groups(
        subset,
        groupby="condition",
        groups=["cirrhotic"],
        reference="healthy",
        method="wilcoxon"
    )
    
    # Extract DE table
    de_df = sc.get.rank_genes_groups_df(
        subset,
        group="cirrhotic"
    )
    
    # Filter significant upregulated genes
    sig_df = de_df[
        (de_df["pvals_adj"] < 0.05) &
        (de_df["logfoldchanges"] > 1)
    ].copy()
    
    # Save both full and significant tables
    de_df.to_csv(outdir / f"{celltype}_cirrhotic_vs_healthy_all.csv", index=False)
    sig_df.to_csv(outdir / f"{celltype}_cirrhotic_vs_healthy_sig_up.csv", index=False)
    
    de_results[celltype] = sig_df
    
    print(f"Significant upregulated genes: {sig_df.shape[0]}")
    display(sig_df.head(15))

# %%
summary_rows = []

for celltype, df in de_results.items():
    top = df.head(10).copy()
    top["cell_type"] = celltype
    summary_rows.append(top)

top_markers_all = pd.concat(summary_rows, ignore_index=True)

